{
  "expo": {
    "name": "Gás do Povo Entregador",
    "slug": "gas-entregador",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "gasentregador",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C140C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gaserp.entregador",
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch"],
        "NSLocationWhenInUseUsageDescription": "Usamos sua localização para registrar o trajeto das entregas em andamento.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Usamos sua localização em segundo plano para acompanhar a entrega até a conclusão da rota.",
        "NSLocationAlwaysUsageDescription": "Usamos sua localização em segundo plano para acompanhar a entrega até a conclusão da rota."
      }
    },
    "android": {
      "package": "com.gaserp.entregador",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C140C"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FB5E13",
          "defaultChannel": "deliveries"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#1C140C"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Usamos sua localização em segundo plano para acompanhar a entrega até a conclusão da rota.",
          "locationWhenInUsePermission": "Usamos sua localização para registrar o trajeto das entregas em andamento.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "165eab5a-801a-45a3-ae81-e0a6ef28e7f3"
      }
    },
    "owner": "lvlparticipacoesltda1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/165eab5a-801a-45a3-ae81-e0a6ef28e7f3"
    }
  }
}
