{
  "name": "@gas-erp/database",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "push": "dotenv -e ../../.env -- prisma db push",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:deploy:force": "dotenv -e ../../.env -- sh -c 'PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 prisma migrate deploy'",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "import:sv-customers": "dotenv -e ../../.env -- tsx scripts/import-sao-vicente-customers.ts",
    "import:grj-customers": "dotenv -e ../../.env -- tsx scripts/import-guaruja-customers.ts",
    "import:sts-customers": "dotenv -e ../../.env -- tsx scripts/import-santos-customers.ts",
    "import:pgsmb-customers": "dotenv -e ../../.env -- tsx scripts/import-pg-samambaia-customers.ts",
    "import:pgpr-customers": "dotenv -e ../../.env -- tsx scripts/import-pg-princesa-customers.ts",
    "backfill:coords": "dotenv -e ../../.env -- tsx scripts/backfill-delivery-coords.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "build": "tsc"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "prisma": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "bcryptjs": "^3.0.2",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
