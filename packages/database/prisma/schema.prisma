generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  ORG_MASTER
  STORE_MANAGER
  ATTENDANT
  FINANCE
  DELIVERER
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  IN_DELIVERY
  DELIVERED
  PORTARIA
  CANCELLED
}

enum BackdateApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum MobileApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum SaleChannel {
  PHONE
  WHATSAPP
  APP
  IN_STORE
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CHECK
  CUSTOMER_CREDIT
  GDP
  OTHER
}

enum PaymentFeeMode {
  NONE
  PERCENT
  FIXED
  PERCENT_AND_FIXED
}

enum StockMovementType {
  IN
  OUT
}

enum StockBucket {
  AVAILABLE
  IN_TRANSIT
  LENT
}

enum StockTransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum DelivererStatus {
  AVAILABLE
  ON_DELIVERY
  OFFLINE
}

enum DeliveryStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

enum FiscalDocumentStatus {
  PENDING
  ISSUED
  CANCELLED
  ERROR
}

enum SupplierType {
  PJ
  PF
}

enum PurchaseInvoiceStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores              Store[]
  users               User[]
  customers           Customer[]
  customerCategories  CustomerCategory[]
  products            Product[]
  suppliers           Supplier[]
  auditLogs           AuditLog[]
  storePaymentMethods StorePaymentMethod[]
}

model Store {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String
  /** Endereço legado (texto livre); preferir campos estruturados abaixo. */
  address        String?
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?
  zipCode        String?
  landmark       String?
  latitude       Float?
  longitude      Float?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userStores          UserStore[]
  productSettings     ProductStoreSetting[]
  stockBalances       StockBalance[]
  stockMovements      StockMovement[]
  transfersFrom       StockTransfer[]       @relation("TransferFrom")
  transfersTo         StockTransfer[]       @relation("TransferTo")
  sales               Sale[]
  delivererStores     DelivererStore[]
  purchaseInvoices    PurchaseInvoice[]
  paymentMethods      StorePaymentMethod[]
  customerProductPrices CustomerProductPrice[]
  customers           Customer[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model StorePaymentMethod {
  id             String         @id @default(cuid())
  storeId        String
  organizationId String
  systemCode     String?
  label          String
  isCustom       Boolean        @default(false)
  enabled        Boolean        @default(true)
  sortOrder      Int            @default(0)
  feeMode        PaymentFeeMode @default(NONE)
  feePercent     Decimal        @db.Decimal(5, 2) @default(0)
  feeFixed       Decimal        @db.Decimal(12, 2) @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments     SalePayment[]

  @@unique([storeId, systemCode])
  @@index([storeId])
  @@index([organizationId])
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  passwordHash   String
  name           String
  phone          String?
  role           UserRole
  active         Boolean  @default(true)
  permissions    String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userStores     UserStore[]
  salesAttendant Sale[]          @relation("SaleAttendant")
  deliverer      Deliverer?
  auditLogs      AuditLog[]
  statusLogs     SaleStatusLog[]
  stockMovements StockMovement[]
  passwordResetTokens PasswordResetToken[]
  salesBackdateApproved Sale[] @relation("SaleBackdateApprover")
  saleBackdateLogs SaleBackdateLog[]
  salesMobileApproved Sale[] @relation("SaleMobileApprover")
  saleMobileApprovalLogs SaleMobileApprovalLog[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model UserStore {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
}

model CustomerCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customers    Customer[]

  @@unique([organizationId, name])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  storeId        String
  categoryId     String?
  name           String
  email          String?
  phone          String?
  document       String?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category     CustomerCategory?  @relation(fields: [categoryId], references: [id])
  addresses    CustomerAddress[]
  sales        Sale[]
  productPrices CustomerProductPrice[]

  @@index([organizationId])
  @@index([storeId])
  @@index([storeId, name])
  @@index([phone])
}

model CustomerAddress {
  id           String   @id @default(cuid())
  customerId   String
  label        String?
  street       String
  number       String?
  complement   String?
  neighborhood String?
  city         String
  state        String
  zipCode      String?
  landmark     String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerProductPrice {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  storeId    String
  price      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId, storeId])
  @@index([storeId, customerId])
}

model Supplier {
  id                String       @id @default(cuid())
  organizationId    String
  type              SupplierType @default(PJ)
  legalName         String
  tradeName         String?
  document          String?
  stateRegistration String?
  email             String?
  phone             String?
  rntrc             String?
  zipCode           String?
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  city              String?
  state             String?
  landmark          String?
  notes             String?
  finalConsumer     Boolean      @default(false)
  publicAgency      Boolean      @default(false)
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseInvoices PurchaseInvoice[]

  @@index([organizationId])
  @@index([legalName])
  @@index([document])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  sku            String
  name           String
  description    String?
  unit           String   @default("UN")
  productType    String   @default("GLP")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  storeSettings   ProductStoreSetting[]
  stockBalances   StockBalance[]
  stockMovements  StockMovement[]
  saleItems       SaleItem[]
  transferItems   StockTransferItem[]
  purchaseItems   PurchaseInvoiceItem[]
  customerPrices  CustomerProductPrice[]

  @@unique([organizationId, sku])
  @@index([organizationId])
}

model ProductStoreSetting {
  id           String   @id @default(cuid())
  productId    String
  storeId      String
  price        Decimal  @db.Decimal(12, 2)
  supplierCost Decimal  @db.Decimal(12, 2) @default(0)
  deliveryFee  Decimal  @db.Decimal(12, 2) @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
}

model StockBalance {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  available Int      @default(0)
  inTransit Int      @default(0) @map("in_transit")
  lent      Int      @default(0)
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  storeId     String
  userId      String?
  type        StockMovementType
  bucket      StockBucket       @default(AVAILABLE)
  quantity    Int
  reason      String
  referenceId String?
  createdAt   DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([storeId, createdAt])
  @@index([productId])
}

model StockTransfer {
  id           String              @id @default(cuid())
  fromStoreId  String
  toStoreId    String
  status       StockTransferStatus @default(PENDING)
  notes        String?
  requestedAt  DateTime            @default(now())
  completedAt  DateTime?

  fromStore Store               @relation("TransferFrom", fields: [fromStoreId], references: [id])
  toStore   Store               @relation("TransferTo", fields: [toStoreId], references: [id])
  items     StockTransferItem[]

  @@index([fromStoreId])
  @@index([toStoreId])
}

model StockTransferItem {
  id         String @id @default(cuid())
  transferId String
  productId  String
  quantity   Int

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])

  @@index([transferId])
}

model Deliverer {
  id                 String          @id @default(cuid())
  userId             String          @unique
  status             DelivererStatus @default(AVAILABLE)
  expoPushToken      String?
  pushTokenUpdatedAt DateTime?
  lastLatitude           Float?
  lastLongitude          Float?
  lastAccuracy           Float?
  lastSeenAt             DateTime?
  gpsStaleReminderSentAt DateTime?
  batteryLevel           Int?
  batteryCharging        Boolean?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stores           DelivererStore[]
  sales            Sale[]           @relation("SaleDeliverer")
  salesCreated     Sale[]           @relation("SaleCreatedByDeliverer")
  deliveries       Delivery[]
}

model DelivererStore {
  id          String   @id @default(cuid())
  delivererId String
  storeId     String
  createdAt   DateTime @default(now())

  deliverer Deliverer @relation(fields: [delivererId], references: [id], onDelete: Cascade)
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([delivererId, storeId])
  @@index([storeId])
}

model Sale {
  id                    String      @id @default(cuid())
  storeId               String
  customerId            String?
  attendantId           String?
  delivererId           String?
  status                SaleStatus  @default(DRAFT)
  channel               SaleChannel @default(PHONE)
  total                 Decimal     @db.Decimal(12, 2) @default(0)
  notes                 String?
  deliveryStreet        String?
  deliveryNumber        String?
  deliveryComplement    String?
  deliveryNeighborhood  String?
  deliveryCity          String?
  deliveryState         String?
  deliveryLandmark      String?
  gasDoPovoBenefit      Boolean     @default(false)
  deliveryFee           Decimal     @db.Decimal(12, 2) @default(0)
  canceledReason        String?
  confirmedAt           DateTime?
  deliveredAt           DateTime?
  canceledAt            DateTime?
  saleDate              DateTime    @default(now())
  backdateApproval      BackdateApprovalStatus @default(NOT_REQUIRED)
  backdateApprovedAt    DateTime?
  backdateApprovedById  String?
  backdateRequestNotes  String?
  backdateRejectionReason String?
  mobileApproval          MobileApprovalStatus @default(NOT_REQUIRED)
  mobileApprovedAt        DateTime?
  mobileApprovedById      String?
  mobileRejectionReason   String?
  createdByDelivererId    String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  store       Store            @relation(fields: [storeId], references: [id])
  customer    Customer?        @relation(fields: [customerId], references: [id])
  attendant   User?            @relation("SaleAttendant", fields: [attendantId], references: [id])
  deliverer   Deliverer?       @relation("SaleDeliverer", fields: [delivererId], references: [id])
  backdateApprovedBy User?     @relation("SaleBackdateApprover", fields: [backdateApprovedById], references: [id])
  mobileApprovedBy User?       @relation("SaleMobileApprover", fields: [mobileApprovedById], references: [id])
  createdByDeliverer Deliverer? @relation("SaleCreatedByDeliverer", fields: [createdByDelivererId], references: [id])
  items       SaleItem[]
  payments    SalePayment[]
  statusLogs  SaleStatusLog[]
  backdateLogs SaleBackdateLog[]
  mobileLogs  SaleMobileApprovalLog[]
  delivery    Delivery?
  fiscalDocs  FiscalDocument[]

  @@index([storeId, createdAt])
  @@index([storeId, saleDate])
  @@index([status])
  @@index([backdateApproval])
  @@index([mobileApproval])
  @@index([createdByDelivererId])
}

model SaleBackdateLog {
  id        String   @id @default(cuid())
  saleId    String
  userId    String?
  action    String
  notes     String?
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([saleId, createdAt])
}

model SaleMobileApprovalLog {
  id        String   @id @default(cuid())
  saleId    String
  userId    String?
  action    String
  notes     String?
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([saleId, createdAt])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  unitCost  Decimal @db.Decimal(12, 2) @default(0)
  discount  Decimal @db.Decimal(12, 2) @default(0)
  total     Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
}

model SalePayment {
  id                   String         @id @default(cuid())
  saleId               String
  method               PaymentMethod
  amount               Decimal        @db.Decimal(12, 2)
  storePaymentMethodId String?
  processingFee        Decimal        @db.Decimal(12, 2) @default(0)
  createdAt            DateTime       @default(now())

  sale               Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)
  storePaymentMethod StorePaymentMethod? @relation(fields: [storePaymentMethodId], references: [id])

  @@index([saleId])
  @@index([storePaymentMethodId])
}

model SaleStatusLog {
  id        String     @id @default(cuid())
  saleId    String
  userId    String?
  status    SaleStatus
  notes     String?
  createdAt DateTime   @default(now())

  sale Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([saleId])
}

model Delivery {
  id                    String         @id @default(cuid())
  saleId                String         @unique
  delivererId           String
  status                DeliveryStatus @default(PENDING)
  startedAt             DateTime?
  completedAt           DateTime?
  pendingReminderSentAt DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  sale            Sale                    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  deliverer       Deliverer               @relation(fields: [delivererId], references: [id])
  trackingPoints  DeliveryTrackingPoint[]

  @@index([delivererId, status])
}

model DeliveryTrackingPoint {
  id         String   @id @default(cuid())
  deliveryId String
  latitude   Float
  longitude  Float
  accuracy   Float?
  recordedAt DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, recordedAt])
}

model FiscalDocument {
  id         String               @id @default(cuid())
  saleId     String
  type       String
  status     FiscalDocumentStatus @default(PENDING)
  provider   String?
  accessKey  String?
  payload    Json?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PurchaseInvoice {
  id         String                @id @default(cuid())
  storeId    String
  supplierId String
  number     String
  issueDate  DateTime
  total      Decimal               @default(0) @db.Decimal(12, 2)
  notes      String?
  status     PurchaseInvoiceStatus @default(CONFIRMED)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  store    Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier Supplier                 @relation(fields: [supplierId], references: [id])
  items    PurchaseInvoiceItem[]
  payments PurchaseInvoicePayment[]

  @@index([storeId, issueDate])
  @@index([supplierId])
}

model PurchaseInvoiceItem {
  id          String    @id @default(cuid())
  invoiceId   String
  productId   String
  quantity    Int
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0) @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(12, 2)
  paymentDate DateTime?
  createdAt   DateTime  @default(now())

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

model PurchaseInvoicePayment {
  id          String   @id @default(cuid())
  invoiceId   String
  category    String
  dueDate     DateTime
  amount      Decimal  @db.Decimal(12, 2)
  installment Int      @default(1)
  createdAt   DateTime @default(now())

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}
